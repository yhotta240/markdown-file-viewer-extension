{
  "manifest_version": 3,
  "name": "Markdown File Viewer Extension",
  "short_name": "Markdown File Viewer",
  "version": "0.0.1",
  "description": "ローカルおよび Web 上の Markdown ファイルを表示するシンプルなビューアー",
  "icons": {
    "48": "icons/icon.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_icon": {
      "48": "icons/icon.png"
    }
  },
  "host_permissions": [
    "https://*/*.md",
    "https://*/*.markdown",
    "file:///*/*.md",
    "file:///*/*.markdown"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*.md",
        "https://*/*.markdown",
        "file:///*/*.md",
        "file:///*/*.markdown"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
