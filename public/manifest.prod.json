{
  "manifest_version": 3,
  "name": "Markdown File Viewer Extension",
  "short_name": "Markdown File Viewer",
  "version": "0.0.2",
  "description": "ローカルおよび Web 上の Markdown ファイルを表示するシンプルなビューアー",
  "icons": {
    "48": "icons/icon.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {},
  "host_permissions": [
    "https://*/*.md",
    "https://*/*.markdown",
    "file:///*/*.md",
    "file:///*/*.markdown"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*.md",
        "https://*/*.markdown",
        "file:///*/*.md",
        "file:///*/*.markdown"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
